{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tome",
  "version": "0.1.0",
  "identifier": "com.hesnottheguy.tome",
  "build": {
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "copyright": "Copyright (c) 2026 HesNotTheGuy",
    "publisher": "HesNotTheGuy",
    "homepage": "https://github.com/HesNotTheGuy/tome",
    "shortDescription": "Offline Wikipedia for the desktop.",
    "longDescription": "Browse and search the entire Wikipedia corpus offline, with granular control over what's stored locally and how much disk it uses."
  }
}
